# ════════════════════════════════════════════════════════════════════════════════
# Secure File Transfer Backend - Environment Configuration
# ════════════════════════════════════════════════════════════════════════════════
#
# This file documents all environment variables required for the backend.
# Copy this file to .env and fill in actual values for your deployment.
#
# SECURITY NOTE: Never commit the actual .env file to version control!
# Always use .env.example for documentation and keep .env in .gitignore.
#
# ════════════════════════════════════════════════════════════════════════════════
# FLASK CORE CONFIGURATION
# ════════════════════════════════════════════════════════════════════════════════

# Flask app entry point (default: app.py)
FLASK_APP=app.py

# Flask environment: 'development', 'testing', or 'production'
FLASK_ENV=development

# Flask debug mode (enable during development only)
FLASK_DEBUG=0

# ════════════════════════════════════════════════════════════════════════════════
# SECURITY SECRETS (REQUIRED - NO DEFAULTS)
# ════════════════════════════════════════════════════════════════════════════════
#
# These secrets have no defaults and startup will abort if missing.
# Generate each with: python -c "import secrets; print(secrets.token_hex(64))"
# Minimum length: 32 characters
#

# Secret key for Flask sessions and CSRF protection
SECRET_KEY=your_secret_key_here_min_32_chars_generate_with_secrets_module

# Secret key for JWT token signing (separate from SECRET_KEY)
JWT_SECRET_KEY=your_jwt_secret_key_here_min_32_chars_generate_with_secrets_module

# Admin password (no default - must be explicitly set, min 12 chars)
ADMIN_PASSWORD=YourAdminPassword123!

# ════════════════════════════════════════════════════════════════════════════════
# DATABASE CONFIGURATION
# ════════════════════════════════════════════════════════════════════════════════

# MySQL Host (default: localhost)
DB_HOST=localhost

# MySQL Port (default: 3306)
DB_PORT=3306

# MySQL Username (default: root)
DB_USER=root

# MySQL Password (required for production, empty by default for local dev)
DB_PASSWORD=

# Database Name (default: secure_files)
DB_NAME=secure_files

# Full database URL (if set, overrides individual DB_* variables)
# Format: mysql+mysqlconnector://username:password@host:port/database
# DATABASE_URL=mysql+mysqlconnector://root:password@localhost:3306/secure_files

# ════════════════════════════════════════════════════════════════════════════════
# REDIS CONFIGURATION (for JWT blocklist, caching, rate limiting, SocketIO)
# ════════════════════════════════════════════════════════════════════════════════

# Redis Host (default: localhost)
REDIS_HOST=localhost

# Redis Port (default: 6379)
REDIS_PORT=6379

# Redis Password (empty by default, set if Redis requires authentication)
REDIS_PASSWORD=

# Redis Database number (default: 0)
# Note: Rate limiter uses DB 1, JWT blocklist uses DB 0
REDIS_DB=0

# Full Redis URL (if set, overrides individual REDIS_* variables)
# Format: redis://[:password@]host:port/db
# REDIS_URL=redis://localhost:6379/0

# ════════════════════════════════════════════════════════════════════════════════
# JWT TOKEN CONFIGURATION
# ════════════════════════════════════════════════════════════════════════════════

# Access token expiration time (built-in: 1 hour)
# JWT_ACCESS_TOKEN_EXPIRES=3600

# Refresh token expiration time (built-in: 30 days)
# JWT_REFRESH_TOKEN_EXPIRES=2592000

# ════════════════════════════════════════════════════════════════════════════════
# EMAIL/SMTP CONFIGURATION (for OTP delivery)
# ════════════════════════════════════════════════════════════════════════════════

# SMTP Server Host (default: smtp.gmail.com)
SMTP_HOST=smtp.gmail.com

# SMTP Server Port (default: 587 for TLS)
SMTP_PORT=587

# SMTP Username/Email Address (required for sending)
# For Gmail: your-email@gmail.com
SMTP_USERNAME=your-email@gmail.com

# SMTP Password (required for sending)
# For Gmail: Use an App Password (not your main password)
# Generate at: https://myaccount.google.com/apppasswords
SMTP_PASSWORD=your_app_password_here

# From Email Address (for OTP emails)
# Default: noreply@securetransfer.com
FROM_EMAIL=noreply@securetransfer.com

# Application Name (shown in emails)
# Default: Secure File Transfer
APP_NAME=Secure File Transfer

# ════════════════════════════════════════════════════════════════════════════════
# OTP (One-Time Password) CONFIGURATION
# ════════════════════════════════════════════════════════════════════════════════

# OTP Code Length (default: 6 digits)
OTP_LENGTH=6

# OTP Expiration Time in Minutes (default: 10)
OTP_EXPIRY_MINUTES=10

# Maximum OTP Verification Attempts (default: 3)
OTP_MAX_ATTEMPTS=3

# ════════════════════════════════════════════════════════════════════════════════
# FILE UPLOAD CONFIGURATION
# ════════════════════════════════════════════════════════════════════════════════

# Maximum File Size in Bytes (default: 10 MB = 10485760)
# Examples: 5242880 (5MB), 52428800 (50MB), 1073741824 (1GB)
MAX_FILE_SIZE=10485760

# Upload Folder Path (default: uploads - relative to backend directory)
UPLOAD_FOLDER=uploads

# Allowed File Extensions (comma-separated, no dots)
# Default: pdf,txt,jpg,jpeg,png,doc,docx,xls,xlsx,ppt,pptx
ALLOWED_EXTENSIONS=pdf,txt,jpg,jpeg,png,doc,docx,xls,xlsx,ppt,pptx,zip,rar

# Maximum Number of Files Per User (default: 1000)
MAX_FILES_PER_USER=1000

# ════════════════════════════════════════════════════════════════════════════════
# SECURITY & PASSWORD CONFIGURATION
# ════════════════════════════════════════════════════════════════════════════════

# Number of Bcrypt Hash Rounds (default: 12)
# Higher = more secure but slower; 12 is recommended
BCRYPT_ROUNDS=12

# Minimum Password Length (default: 8 characters)
PASSWORD_MIN_LENGTH=8

# Maximum Password Length (default: 100 characters)
PASSWORD_MAX_LENGTH=100

# ════════════════════════════════════════════════════════════════════════════════
# ENCRYPTION CONFIGURATION
# ════════════════════════════════════════════════════════════════════════════════

# RSA Key Size in Bits (default: 2048)
# Higher = more secure but slower; 2048 is standard, 4096 for maximum security
RSA_KEY_SIZE=2048

# AES Key Size in Bytes (default: 32 = 256 bits)
# Standard: 16 (128-bit), 24 (192-bit), 32 (256-bit)
AES_KEY_SIZE=32

# AES IV (Initialization Vector) Size in Bytes for GCM (default: 12)
# GCM standard: 12 bytes (96 bits) is recommended
AES_IV_SIZE=12

# AES GCM Authentication Tag Size in Bytes (default: 16)
# Standard: 16 bytes (128 bits) for GCM
AES_TAG_SIZE=16

# PBKDF2 Key Derivation Function Rounds (default: 100,000)
# Higher = more secure but slower for encryption/decryption
# Used when encrypting private keys
KDF_ROUNDS=100000

# PBKDF2 Salt Size in Bytes (default: 32 = 256 bits)
KDF_SALT_SIZE=32

# ════════════════════════════════════════════════════════════════════════════════
# CORS (Cross-Origin Resource Sharing) CONFIGURATION
# ════════════════════════════════════════════════════════════════════════════════

# Allowed CORS Origins (comma-separated)
# Default: http://localhost:3000,http://localhost:5173
# Production: Set to actual frontend domain(s) only
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Allowed CORS Methods (comma-separated)
# Default: GET,POST,PUT,DELETE,OPTIONS
CORS_METHODS=GET,POST,PUT,DELETE,OPTIONS

# Allowed CORS Headers (comma-separated)
# Default: Content-Type,Authorization
CORS_HEADERS=Content-Type,Authorization

# ════════════════════════════════════════════════════════════════════════════════
# SOCKETIO (WebSocket) CONFIGURATION
# ════════════════════════════════════════════════════════════════════════════════

# SocketIO Message Queue (uses Redis)
# Allows horizontal scaling of SocketIO
# Default: uses REDIS_URL
# SOCKETIO_MESSAGE_QUEUE=redis://localhost:6379/0

# SocketIO Ping Timeout in Seconds (default: 60)
# How long to wait before considering connection dead
SOCKETIO_PING_TIMEOUT=60

# SocketIO Ping Interval in Seconds (default: 25)
# How often to ping connected clients
SOCKETIO_PING_INTERVAL=25

# SocketIO CORS Allowed Origins (comma-separated)
# Default: http://localhost:3000,http://localhost:5000,http://localhost:5173
# PRODUCTION WARNING: Replace with actual frontend domain(s)
SOCKETIO_CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5000,http://localhost:5173

# ════════════════════════════════════════════════════════════════════════════════
# RATE LIMITING CONFIGURATION
# ════════════════════════════════════════════════════════════════════════════════

# Default Rate Limit for all endpoints (default: 100/hour)
RATE_LIMIT_DEFAULT=100/hour

# Rate Limit for Login Endpoint (default: 5/minute)
RATE_LIMIT_LOGIN=5/minute

# Rate Limit for OTP Endpoint (default: 3/minute)
RATE_LIMIT_OTP=3/minute

# Rate Limit for File Upload (default: 10/hour)
RATE_LIMIT_UPLOAD=10/hour

# ════════════════════════════════════════════════════════════════════════════════
# OPTIONAL: MONITORING & LOGGING CONFIGURATION
# ════════════════════════════════════════════════════════════════════════════════

# Log Level (default: INFO)
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# ════════════════════════════════════════════════════════════════════════════════
# QUICK START GUIDE
# ════════════════════════════════════════════════════════════════════════════════
#
# 1. Copy this file:
#    cp .env.example .env
#
# 2. Generate required secrets:
#    python -c "import secrets; print('SECRET_KEY=' + secrets.token_hex(64))"
#    python -c "import secrets; print('JWT_SECRET_KEY=' + secrets.token_hex(64))"
#
# 3. Set database credentials:
#    DB_USER=your_mysql_user
#    DB_PASSWORD=your_mysql_password
#    DB_NAME=secure_files
#
# 4. Set email configuration:
#    SMTP_USERNAME=your-email@gmail.com
#    SMTP_PASSWORD=your_app_password
#
# 5. For development, you can use most defaults:
#    - Redis: localhost:6379
#    - MySQL: localhost:3306
#    - Flask Debug: 1 (for development only!)
#
# 6. For production, CRITICAL changes:
#    - Set FLASK_ENV=production
#    - Set FLASK_DEBUG=0
#    - Replace CORS_ORIGINS with actual domain
#    - Replace SOCKETIO_CORS_ALLOWED_ORIGINS with actual domain
#    - Use strong admin password (min 12 chars, mix of types)
#    - Set DATABASE_URL to production database
#    - Set REDIS_URL to production Redis
#    - Enable SSL/TLS for Email (SMTP_PORT=465)
#    - Use Redis AUTH if available
#
# ════════════════════════════════════════════════════════════════════════════════
